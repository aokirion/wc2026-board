{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Write",
      "Bash(node scripts/validate.mjs)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add data.json)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/guard.mjs" }
        ]
      }
    ]
  }
}
